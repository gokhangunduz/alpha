---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  activeNav?: 'about' | 'changelog' | 'contact';
}

const { title, description, path = '/', activeNav } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = `https://gokhangunduz.github.io${base}${path === '/' ? '' : path}`;
const ogImage = `${base}/og.png`;

const navItems = [
  { href: `${base}/about`,     label: 'About',     key: 'about'     },
  { href: `${base}/changelog`, label: 'Changelog', key: 'changelog' },
  { href: `${base}/contact`,   label: 'Contact',   key: 'contact'   },
] as const;

const MARKETPLACE_URL = 'https://marketplace.visualstudio.com/items?itemName=gokhangunduz.alpha';
const GITHUB_URL = 'https://github.com/gokhangunduz/alpha';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="alpha" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
  <meta name="theme-color" content="#0d1117" />
</head>
<body class="bg-bg text-fg leading-relaxed">
  <a
    href="#main"
    class="absolute -top-full left-4 z-[999] px-4 py-2 bg-accent text-white rounded text-sm font-semibold no-underline focus:top-4"
  >
    Skip to content
  </a>

  <nav class="sticky top-0 z-[100] border-b border-border/60 bg-bg/80 backdrop-blur-xl" style="backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px);">
    <div class="mx-auto flex max-w-site items-center justify-between px-6 py-3.5">
      <a href={`${base}/`} class="flex items-center gap-2.5 text-[15px] font-semibold text-fg no-underline">
        <img src={`${base}/favicon.png`} alt="" width="26" height="26" class="rounded-md" />
        alpha
      </a>

      <div class="flex items-center gap-6">
        {navItems.map(({ href, label, key }) => (
          <a
            href={href}
            class={`text-[13px] no-underline transition-colors duration-200 ${activeNav === key ? 'text-fg' : 'text-muted hover:text-fg'}`}
          >
            {label}
          </a>
        ))}
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener"
          class="text-[13px] text-muted hover:text-fg no-underline transition-colors"
          aria-label="GitHub repository"
        >
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main id="main">
    <slot />
  </main>

  <footer class="border-t border-border/60 max-w-site mx-auto px-6 py-8 mt-12">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <p class="text-[13px] text-dim">&copy; 2026 G&ouml;khan G&uuml;nd&uuml;z &middot; MIT License</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <a href={`${base}/about`}     class="text-[13px] text-dim hover:text-muted no-underline transition-colors">About</a>
        <a href={`${base}/changelog`} class="text-[13px] text-dim hover:text-muted no-underline transition-colors">Changelog</a>
        <a href={`${base}/contact`}   class="text-[13px] text-dim hover:text-muted no-underline transition-colors">Contact</a>
        <a href={MARKETPLACE_URL} target="_blank" rel="noopener" class="text-[13px] text-dim hover:text-muted no-underline transition-colors">Marketplace</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="text-[13px] text-dim hover:text-muted no-underline transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</body>
</html>
