---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  activeNav?: 'privacy' | 'terms' | 'contact' | 'about' | 'faq' | 'changelog';
  schema?: Record<string, unknown>;
  heading: string;
  subtitle: string;
}

const { heading, subtitle, ...baseProps } = Astro.props;
---

<BaseLayout {...baseProps}>
  <div class="max-w-narrow mx-auto px-6 py-[60px] pb-20 md:py-8 md:pb-14">
    <header class="mb-0">
      <h1 class="text-[34px] font-bold tracking-[-0.5px] mb-1.5 text-text-primary">{heading}</h1>
      <p class="text-[17px] text-text-secondary mb-12">{subtitle}</p>
    </header>

    <div class="
      [&_h2]:text-[22px] [&_h2]:font-semibold [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-text-primary
      [&_p]:text-[16px] [&_p]:text-text-tertiary [&_p]:mb-4
      [&_strong]:text-text-strong
      [&_ul]:list-none [&_ul]:p-0 [&_ul]:mb-4
      [&_li]:relative [&_li]:pl-5 [&_li]:py-1.5 [&_li]:text-[16px] [&_li]:text-text-tertiary
      [&_li]:before:absolute [&_li]:before:left-0 [&_li]:before:top-[14px]
      [&_li]:before:w-1.5 [&_li]:before:h-1.5 [&_li]:before:bg-accent-orange [&_li]:before:rounded-full [&_li]:before:content-['']
      [&_a]:text-accent-orange [&_a]:no-underline [&_a]:transition-colors [&_a:hover]:text-accent-orange-h
    ">
      <slot />
    </div>
  </div>
</BaseLayout>
