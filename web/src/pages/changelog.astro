---
import BaseLayout from '../layouts/BaseLayout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const changelogPath = path.resolve('../CHANGELOG.md');
const raw = fs.readFileSync(changelogPath, 'utf-8');
const html = marked.parse(raw, { gfm: true });
---

<BaseLayout
  title="Changelog — alpha"
  description="Release notes for the alpha VS Code theme."
  path="/changelog"
  activeNav="changelog"
>
  <section class="max-w-site mx-auto px-6 pt-16 pb-20">
    <header class="mb-10">
      <p class="text-[12px] uppercase tracking-wider text-dim mb-3">Release notes</p>
      <h1 class="text-[40px] md:text-[48px] font-bold tracking-[-1.5px]">Changelog</h1>
    </header>
    <article class="changelog" set:html={html}></article>
  </section>
</BaseLayout>

<style is:global>
  .changelog {
    color: rgb(var(--c-fg));
    font-size: 15px;
    line-height: 1.7;
  }
  .changelog h1 { display: none; }
  .changelog h2 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.4px;
    margin-top: 40px;
    margin-bottom: 8px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgb(var(--c-border) / 0.6);
  }
  .changelog h2:first-of-type { margin-top: 0; }
  .changelog h3 {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--c-muted));
    margin-top: 24px;
    margin-bottom: 8px;
  }
  .changelog ul {
    list-style: disc;
    padding-left: 24px;
    margin-bottom: 8px;
  }
  .changelog li { margin-bottom: 6px; color: rgb(var(--c-muted)); }
  .changelog li::marker { color: rgb(var(--c-dim)); }
  .changelog p { color: rgb(var(--c-muted)); margin-bottom: 12px; }
  .changelog a {
    color: rgb(var(--c-accent));
    text-decoration: none;
  }
  .changelog a:hover { text-decoration: underline; }
  .changelog code {
    background: rgb(var(--c-surface));
    border: 1px solid rgb(var(--c-border) / 0.6);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 13px;
    color: rgb(var(--c-fg));
  }
  .changelog strong { color: rgb(var(--c-fg)); font-weight: 600; }
</style>
