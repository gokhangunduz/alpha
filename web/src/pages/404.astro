---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Not found — alpha"
  description="The page you are looking for does not exist."
  path="/404"
>
  <section class="max-w-site mx-auto px-6 pt-32 pb-24 text-center">
    <p class="font-mono text-[14px] text-dim mb-4">404</p>
    <h1 class="text-[40px] md:text-[56px] font-bold tracking-[-1.5px] mb-4">Not found</h1>
    <p class="text-[17px] text-muted max-w-[440px] mx-auto mb-10">
      That route does not match any page in this site.
    </p>
    <a
      href={`${base}/`}
      class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border hover:border-muted text-fg font-semibold text-[15px] no-underline transition-colors"
    >
      &larr; Back home
    </a>
  </section>
</BaseLayout>
