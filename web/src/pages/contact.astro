---
import ContentLayout from '../layouts/ContentLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ISSUES_NEW = 'https://github.com/gokhangunduz/alpha/issues/new/choose';
---

<ContentLayout
  title="Contact — alpha"
  description="Get in touch with the alpha developer."
  path="/contact"
  activeNav="contact"
  heading="Contact"
  subtitle="Have a question, feedback, or feature request? I'd love to hear from you."
>
  <div class="contact-grid grid gap-4 my-8 [&_p]:!mb-0">
    <a href="mailto:me@gokhangunduz.dev" class="block bg-surface border border-border/60 rounded-2xl px-6 py-7 no-underline transition-all hover:border-muted/60 hover:-translate-y-0.5">
      <h3 class="text-[15px] font-semibold text-fg mb-1">Email</h3>
      <p class="text-[14px] !text-muted">me@gokhangunduz.dev</p>
    </a>
    <a href="https://gokhangunduz.dev" target="_blank" rel="noopener" class="block bg-surface border border-border/60 rounded-2xl px-6 py-7 no-underline transition-all hover:border-muted/60 hover:-translate-y-0.5">
      <h3 class="text-[15px] font-semibold text-fg mb-1">Website</h3>
      <p class="text-[14px] !text-muted">gokhangunduz.dev</p>
    </a>
  </div>

  <h2>Support</h2>
  <p>If you've found a bug, please <a href={ISSUES_NEW} target="_blank" rel="noopener">open an issue on GitHub</a> with your VS Code version, the alpha version, and a screenshot if relevant.</p>

  <h2>Feature requests</h2>
  <p>Got an idea or a color suggestion? <a href={ISSUES_NEW} target="_blank" rel="noopener">Open a feature request</a> on GitHub.</p>

  <h2>About the developer</h2>
  <p>Want to know more about the developer behind alpha? Visit the <a href={`${base}/about`}>About page</a>.</p>
</ContentLayout>

<style>
  .contact-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 520px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
